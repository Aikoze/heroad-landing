---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Heroad",
  "description": "Logiciel de gestion de flotte VTC et transport de personnes",
  "url": "https://heroad.app",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web, iOS, Android",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "description": "Gratuit pour les chauffeurs avec 1 véhicule"
  }
};

const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
    title: 'Planification et dispatch intelligent',
    description: 'Envoyez vos missions à vos partenaires en un clic. Ils reçoivent un accès dédié pour gérer leurs missions en temps réel.',
    link: '/dispatch-missions'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
    title: 'Synchronisation calendrier',
    description: 'Vos missions se synchronisent automatiquement avec votre calendrier. Pas de double saisie, pas de confusion.',
    link: '/app-chauffeur'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    title: 'Gestion de flotte centralisée',
    description: 'Suivez tous vos véhicules et chauffeurs en un seul endroit. Notifications intelligentes pour les missions urgentes.',
    link: '/gestion-flotte'
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Gratuit pour les chauffeurs indépendants',
    description: 'Les chauffeurs indépendants peuvent organiser leurs missions sans frais. Payez seulement si vous gérez plusieurs véhicules.',
    link: '/app-chauffeur'
  }
];

const advantages = [
  'Spécialisé VTC & Transport de personnes (pas généraliste)',
  'Gratuit pour les chauffeurs indépendants',
  'Dispatch intelligent + synchronisation calendrier',
  'Pas de commission sur les missions (contrairement aux plateformes)'
];
---

<Layout
  title="Heroad - Logiciel de gestion de flotte VTC & Transport de personnes"
  description="Heroad : planifiez vos missions, gérez votre flotte VTC/LOTI et synchronisez avec iOS, Android et le Web. Gratuit pour les chauffeurs indépendants. Essai gratuit pour les régulateurs."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-primary to-primary-light py-20 sm:py-28">
    <!-- Decorative grid -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-accent text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
          Disponible sur iOS, Android et Web
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight">
          Logiciel de gestion de flotte dédié aux
          <span class="text-accent">VTC et Transport de personnes</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-gray-300 leading-relaxed max-w-2xl">
          Planifiez vos missions, gérez vos chauffeurs et synchronisez avec votre calendrier.
          Gratuit pour les chauffeurs indépendants. Essai gratuit pour les régulateurs.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-start gap-4">
          <a
            href="https://app.heroad.app"
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 rounded-xl bg-accent text-primary text-base font-bold hover:bg-accent-dark transition-all shadow-lg shadow-accent/20"
          >
            Essai gratuit 14 jours
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href="/app-chauffeur"
            class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 rounded-xl border-2 border-gray-500 text-white text-base font-semibold hover:border-gray-300 transition-colors"
          >
            Chauffeur indépendant ? C'est gratuit
          </a>
        </div>

        <p class="mt-4 text-sm text-gray-400">Pas de carte bancaire requise</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-primary">
          Tout ce dont vous avez besoin pour gérer votre flotte VTC
        </h2>
        <p class="mt-4 text-lg text-text-muted">
          Une plateforme complète pour les régulateurs, les sociétés de transport et les chauffeurs indépendants.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {features.map(feature => (
          <a href={feature.link} class="group block p-8 rounded-2xl border border-gray-100 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 transition-all">
            <div class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-5 group-hover:bg-accent/20 transition-colors">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">{feature.title}</h3>
            <p class="text-text-muted leading-relaxed">{feature.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY HEROAD -->
  <section id="why-heroad" class="py-20 sm:py-28 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-primary">
            Pourquoi choisir Heroad plutôt qu'une plateforme généraliste ?
          </h2>
          <p class="mt-4 text-lg text-text-muted">
            Les logiciels de gestion de flotte généralistes ne sont pas conçus pour les spécificités du transport VTC. Heroad l'est.
          </p>
        </div>

        <div class="space-y-4">
          {advantages.map(advantage => (
            <div class="flex items-start gap-4 p-4 bg-white rounded-xl border border-gray-100">
              <div class="w-8 h-8 rounded-lg bg-success/10 text-success flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="text-base font-medium text-primary">{advantage}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-primary">
          Comment ça marche ?
        </h2>
        <p class="mt-4 text-lg text-text-muted">
          Prise en main en moins de 5 minutes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">1</div>
          <h3 class="text-lg font-bold text-primary mb-2">Créez votre compte</h3>
          <p class="text-text-muted">Inscription en 30 secondes. Ajoutez vos véhicules et chauffeurs.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">2</div>
          <h3 class="text-lg font-bold text-primary mb-2">Planifiez vos missions</h3>
          <p class="text-text-muted">Créez et assignez des missions. Vos chauffeurs reçoivent une notification.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-primary text-white flex items-center justify-center text-xl font-bold mx-auto mb-5">3</div>
          <h3 class="text-lg font-bold text-primary mb-2">Suivez en temps réel</h3>
          <p class="text-text-muted">Voyez le statut de chaque mission. Synchronisation calendrier automatique.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING HINT -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-primary">
          Tarifs simples et transparents
        </h2>
        <p class="mt-4 text-lg text-text-muted">
          Pas de commission sur vos missions. Pas de frais cachés.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <!-- Free -->
        <div class="p-8 rounded-2xl bg-white border border-gray-200">
          <h3 class="text-lg font-bold text-primary">Chauffeur indépendant</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold text-primary">0&euro;</span>
            <span class="text-text-muted">/mois</span>
          </div>
          <p class="mt-2 text-sm text-text-muted">Pour les chauffeurs avec 1 véhicule</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-sm">
              <svg class="w-4 h-4 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Gestion de vos missions
            </li>
            <li class="flex items-center gap-3 text-sm">
              <svg class="w-4 h-4 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Synchronisation calendrier
            </li>
            <li class="flex items-center gap-3 text-sm">
              <svg class="w-4 h-4 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Notifications en temps réel
            </li>
          </ul>
          <a
            href="https://app.heroad.app"
            class="mt-8 w-full inline-flex items-center justify-center px-6 py-3 rounded-xl border-2 border-primary text-primary text-sm font-bold hover:bg-primary hover:text-white transition-colors"
          >
            Commencer gratuitement
          </a>
        </div>

        <!-- Pro -->
        <div class="p-8 rounded-2xl bg-primary text-white relative overflow-hidden">
          <div class="absolute top-4 right-4 px-2.5 py-1 rounded-full bg-accent/20 text-accent text-xs font-semibold">Populaire</div>
          <h3 class="text-lg font-bold">Régulateur / Flotte</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-extrabold">Essai gratuit</span>
          </div>
          <p class="mt-2 text-sm text-gray-400">14 jours, puis tarif adapté à votre flotte</p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-sm text-gray-200">
              <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Tout du plan gratuit
            </li>
            <li class="flex items-center gap-3 text-sm text-gray-200">
              <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Dispatch intelligent multi-chauffeurs
            </li>
            <li class="flex items-center gap-3 text-sm text-gray-200">
              <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Gestion des partenaires
            </li>
            <li class="flex items-center gap-3 text-sm text-gray-200">
              <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Véhicules illimités
            </li>
          </ul>
          <a
            href="https://app.heroad.app"
            class="mt-8 w-full inline-flex items-center justify-center px-6 py-3 rounded-xl bg-accent text-primary text-sm font-bold hover:bg-accent-dark transition-colors"
          >
            Essai gratuit 14 jours
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA />
</Layout>
