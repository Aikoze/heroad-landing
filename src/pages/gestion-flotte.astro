---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Heroad - Gestion de flotte VTC",
  "description": "Logiciel de gestion de flotte specialise VTC et transport de personnes",
  "brand": { "@type": "Brand", "name": "Heroad" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
};

const features = [
  {
    title: 'Suivi en temps reel de vos vehicules',
    description: 'Localisez chaque vehicule de votre flotte en temps reel. Recevez des notifications pour les missions urgentes ou les problemes de disponibilite.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`
  },
  {
    title: 'Planification intelligente des missions',
    description: 'Assignez automatiquement les missions aux chauffeurs disponibles. Optimisez les trajets et reduisez les temps d\'attente.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`
  },
  {
    title: 'Gestion des chauffeurs et partenaires',
    description: 'Creez des acces dedies pour vos partenaires. Ils gerent leurs missions sans acceder a vos donnees sensibles.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`
  },
  {
    title: 'Synchronisation calendrier iOS',
    description: 'Les missions s\'ajoutent automatiquement au calendrier Apple. Vos chauffeurs voient leurs plannings sans quitter leur app preferee.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`
  }
];

const comparison = [
  { feature: 'Specialise VTC', heroad: true, fleetnote: false, gac: false },
  { feature: 'Dispatch intelligent', heroad: true, fleetnote: false, gac: 'partial' },
  { feature: 'Synchronisation iOS', heroad: true, fleetnote: false, gac: false },
  { feature: 'Gratuit pour solo', heroad: true, fleetnote: false, gac: false },
  { feature: 'Tarif', heroad: 'Gratuit - Premium', fleetnote: 'A partir de 99\u20ac/mois', gac: 'Sur devis' }
];
---

<Layout
  title="Logiciel de gestion de flotte automobile VTC - Heroad"
  description="Gerez votre flotte VTC en temps reel : suivi des vehicules, planification des missions, notifications intelligentes. Essai gratuit."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-primary to-primary-light py-20 sm:py-24">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-accent hover:text-accent-dark transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Retour a l'accueil
        </a>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight">
          Logiciel de gestion de flotte pour <span class="text-accent">VTC et transport de personnes</span>
        </h1>
        <p class="mt-6 text-lg text-gray-300 leading-relaxed max-w-2xl">
          Contrairement aux logiciels generalistes, Heroad est concu specifiquement pour les regulateurs VTC, les societes de transport et les chauffeurs independants.
        </p>
        <a
          href="https://app.heroad.app"
          class="mt-8 inline-flex items-center px-8 py-4 rounded-xl bg-accent text-primary text-base font-bold hover:bg-accent-dark transition-colors"
        >
          Essai gratuit 14 jours
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-primary text-center mb-16">
        Fonctionnalites de gestion de flotte
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {features.map((feature, i) => (
          <div class="p-8 rounded-2xl border border-gray-100 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-5">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">{`${i + 1}. ${feature.title}`}</h3>
            <p class="text-text-muted leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-primary text-center mb-4">
        Heroad vs autres logiciels de gestion de flotte
      </h2>
      <p class="text-center text-text-muted mb-12 max-w-2xl mx-auto">
        Comparez Heroad avec les solutions generalistes du marche.
      </p>

      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left py-4 px-6 font-semibold text-text-muted">Fonctionnalite</th>
              <th class="text-center py-4 px-6 font-bold text-primary bg-accent/5">Heroad</th>
              <th class="text-center py-4 px-6 font-semibold text-text-muted">FleetNote</th>
              <th class="text-center py-4 px-6 font-semibold text-text-muted">GAC Car Fleet</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map(row => (
              <tr class="border-b border-gray-50 last:border-0">
                <td class="py-4 px-6 font-medium">{row.feature}</td>
                <td class="py-4 px-6 text-center bg-accent/5">
                  {typeof row.heroad === 'boolean'
                    ? row.heroad
                      ? <span class="text-success font-semibold">Oui</span>
                      : <span class="text-error">Non</span>
                    : <span class="font-semibold text-primary">{row.heroad}</span>
                  }
                </td>
                <td class="py-4 px-6 text-center">
                  {typeof row.fleetnote === 'boolean'
                    ? row.fleetnote
                      ? <span class="text-success">Oui</span>
                      : <span class="text-gray-400">Non</span>
                    : <span class="text-text-muted">{row.fleetnote}</span>
                  }
                </td>
                <td class="py-4 px-6 text-center">
                  {typeof row.gac === 'boolean'
                    ? row.gac
                      ? <span class="text-success">Oui</span>
                      : <span class="text-gray-400">Non</span>
                    : row.gac === 'partial'
                      ? <span class="text-yellow-500">Limite</span>
                      : <span class="text-text-muted">{row.gac}</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-extrabold text-primary text-center mb-10">Decouvrir aussi</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <a href="/dispatch-missions" class="p-6 rounded-xl border border-gray-100 hover:border-accent/30 hover:shadow-md transition-all group">
          <h3 class="font-bold text-primary group-hover:text-accent transition-colors">Dispatch intelligent</h3>
          <p class="text-sm text-text-muted mt-1">Automatisez l'assignation de vos missions</p>
        </a>
        <a href="/app-chauffeur" class="p-6 rounded-xl border border-gray-100 hover:border-accent/30 hover:shadow-md transition-all group">
          <h3 class="font-bold text-primary group-hover:text-accent transition-colors">App chauffeur</h3>
          <p class="text-sm text-text-muted mt-1">L'application mobile pour vos chauffeurs</p>
        </a>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
