---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Commencez gratuitement',
  subtitle = 'Pas de carte bancaire requise. Acces complet aux fonctionnalites pendant 14 jours.'
} = Astro.props;
---

<section class="py-20 bg-primary">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">{title}</h2>
    <p class="text-lg text-gray-300 mb-8">{subtitle}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://app.heroad.app"
        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-accent text-primary text-base font-bold hover:bg-accent-dark transition-colors"
      >
        Essai gratuit 14 jours
      </a>
      <a
        href="/app-chauffeur"
        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 rounded-xl border-2 border-gray-600 text-white text-base font-semibold hover:border-gray-400 transition-colors"
      >
        Chauffeur solo ? C'est gratuit
      </a>
    </div>
  </div>
</section>
